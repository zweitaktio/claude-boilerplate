#!/bin/bash

# Load nvm if available
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# Fallback PATH additions
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only)

# Check if any backend files are staged
if echo "$STAGED_FILES" | grep -q "^backend/"; then
  echo "Running yarn check in backend..."
  cd backend && yarn check
  if [ $? -ne 0 ]; then
    echo "Backend check failed. Commit aborted."
    exit 1
  fi
  cd ..
fi

# Check if any frontend files are staged
if echo "$STAGED_FILES" | grep -q "^frontend/"; then
  echo "Running yarn check in frontend..."
  cd frontend && yarn check
  if [ $? -ne 0 ]; then
    echo "Frontend check failed. Commit aborted."
    exit 1
  fi
  cd ..
fi

exit 0
