{
  "name": "@myproject/services",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Development services and operations tools",
  "scripts": {
    "start": "docker compose -f docker-compose.dev.yml up -d --remove-orphans && yarn oauth:setup",
    "oauth:setup": "tsx scripts/setup-hydra-clients.ts",
    "stop": "docker compose -f docker-compose.dev.yml down --remove-orphans",
    "destroy": "docker compose -f docker-compose.dev.yml down --volumes --remove-orphans",
    "sync": "tsx src/cli.ts sync",
    "sync:db": "tsx src/cli.ts sync --db-only",
    "sync:r2": "tsx src/cli.ts sync --r2-only",
    "sync:dry-run": "tsx src/cli.ts sync --dry-run",
    "status": "tsx src/cli.ts check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "ora": "^8.1.1",
    "pg": "^8.13.1",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/ssh2": "^1.15.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "yarn@4.12.0"
}
