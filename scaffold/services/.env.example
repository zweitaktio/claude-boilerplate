# ─── SSH to Production Server ─────────────────────────────────────
SSH_HOST=
SSH_PORT=22
SSH_USER=root
# SSH_KEY_PATH=~/.ssh/id_rsa  # Optional, defaults to ~/.ssh/id_rsa

# ─── Production Database (Docker container on server) ─────────────
PROD_DB_HOST=           # Docker container name on production server
PROD_DB_PORT=5432
PROD_DB_USER=
PROD_DB_PASS=
PROD_DB_NAME=

# ─── Local Database (Docker) ─────────────────────────────────────
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=5432
LOCAL_DB_USER=postgres
LOCAL_DB_PASS=postgres
LOCAL_DB_NAME=myproject

# ─── Test/Staging Database (optional) ────────────────────────────
# TEST_SSH_HOST=
# TEST_SSH_PORT=22
# TEST_SSH_USER=root
# TEST_DB_HOST=           # Docker container name on test server
# TEST_DB_PORT=5432
# TEST_DB_USER=
# TEST_DB_PASS=
# TEST_DB_NAME=

# ─── R2/S3 Storage — Production ──────────────────────────────────
R2_PROD_ACCOUNT_ID=
R2_PROD_ACCESS_KEY_ID=
R2_PROD_SECRET_ACCESS_KEY=
R2_PROD_BUCKET=

# ─── R2/S3 Storage — Development ─────────────────────────────────
R2_DEV_ACCOUNT_ID=
R2_DEV_ACCESS_KEY_ID=
R2_DEV_SECRET_ACCESS_KEY=
R2_DEV_BUCKET=

# ─── R2/S3 Storage — Test (optional) ─────────────────────────────
# R2_TEST_ACCOUNT_ID=
# R2_TEST_ACCESS_KEY_ID=
# R2_TEST_SECRET_ACCESS_KEY=
# R2_TEST_BUCKET=

# ─── OPTIONAL: Ory Hydra OAuth2 ──────────────────────────────────
# HYDRA_ADMIN_URL=http://localhost:4445
# OAUTH_CLIENT_SECRET=change-me
# M2M_CLIENT_SECRET=change-me
# PAYLOAD_OAUTH_CLIENT_SECRET=change-me
# OAUTH_REDIRECT_URI=http://localhost:5173/oauth/callback
